########################################
# CN statepoint NVT production + RDF
# Generated by models/statepoint_eval/prepare_runs.py
########################################

variable temp         equal {{TEMPERATURE_K}}
variable seed         equal {{SEED}}
variable delt         equal 0.2
variable equil_steps  equal {{EQUIL_STEPS}}
variable prod_steps   equal {{PROD_STEPS}}
variable thermo_freq  equal 100
variable dump_freq    equal 500
variable rdf_bins     equal 200
variable rdf_rmax     equal 8.0

units           real
newton          on
atom_style      atomic
atom_modify     sort 0 0.0
atom_modify     map array

neighbor        1.0 bin
neigh_modify    delay 0 every 1 check yes

read_data       data.in
velocity        all create ${temp} ${seed} loop all mom yes rot yes dist gaussian

pair_style      chimesFF fingerprint 1
pair_coeff      * * params.txt

timestep        ${delt}

thermo_style    custom step time ke pe etotal temp press vol
thermo_modify   line one format float %20.5f flush yes
thermo          ${thermo_freq}

fix             nvt all nvt temp ${temp} ${temp} 100.0

dump            1 all custom ${dump_freq} traj.lammpstrj element xu yu zu
dump_modify     1 sort id element C N

run             ${equil_steps}

reset_timestep  0
unfix           nvt
fix             nvt all nvt temp ${temp} ${temp} 100.0

compute         rdf all rdf ${rdf_bins} 1 1 1 2 2 2 cutoff ${rdf_rmax}
fix             rdf_avg all ave/time 100 10 1000 c_rdf[*] file rdf.dat mode vector

run             ${prod_steps}
